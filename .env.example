# SQLite by default; point this at a Postgres URL to switch storage backends.
DATABASE_URL=sqlite:///./platform.db

# Local Ollama runtime. No external LLM API calls are made anywhere in this app.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# User-Agent sent by the web scraping tools.
SCRAPER_USER_AGENT=agentic-platform-bot/0.1
